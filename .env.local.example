# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=greenqubes-files
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Cloudflare Images (auto-resize) ───────────────────────────────────────────
CF_IMAGES_ACCOUNT_ID=your-cloudflare-account-id
CF_IMAGES_API_TOKEN=your-images-api-token
CF_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-account-hash

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Voyage AI (embeddings) ────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=generate-a-random-32-char-string
TELEGRAM_BUG_BOT_TOKEN=your-bug-bot-token
TELEGRAM_BUG_CHAT_ID=your-bug-chat-id

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Vercel auto-generates and injects CRON_SECRET for deployed projects.
# For local testing, set any string here and pass it as: Authorization: Bearer <value>
CRON_SECRET=generate-a-random-32-char-string

# ── Obsidian sync ──────────────────────────────────────────────────────────────
# Absolute path to your local Obsidian vault folder (used by npm run obsidian-sync)
OBSIDIAN_VAULT_PATH=C:/Users/YourName/Documents/MyVault

# ── App URL (for digest promote links) ───────────────────────────────────────
# Set to your Vercel deployment URL in production; localhost for local testing
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Crash log (dev only) ───────────────────────────────────────────────────────
# If set, crash reports are also written as .md files to this local folder.
# Leave unset in production (Vercel) — Supabase is the only store.
# CRASH_LOG_DIR=C:/Greenqubes_GitHub/crash-logs

# ── Bug reports sync ───────────────────────────────────────────────────────────
# If set, bug reports are written as .md files to this local folder (dev only).
# Run nightly via: npm run sync-bugs
BUG_LOG_DIR=C:/Greenqubes_GitHub/greenqubes-ops/bugs_reported
APP_VERSION=pre-alpha

# GitHub integration for bug tracking (optional)
# Leave unset to skip GitHub issue creation. Set to enable automatic GitHub issues.
# GITHUB_TOKEN=ghp_your-github-personal-access-token
# GITHUB_REPO=Greenqubes/greenqubes-ops
